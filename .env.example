# Public build-time values only. Never put secrets in VITE_* variables.
# Leave the base URL empty when nginx or Vite proxies the backend on the same origin.
VITE_API_BASE_URL=
VITE_API_TIMEOUT_MS=10000
VITE_API_MAX_REQUEST_BYTES=307200
VITE_API_MAX_RESPONSE_BYTES=1048576
VITE_ENVIRONMENT_NAME=Local / Configured
